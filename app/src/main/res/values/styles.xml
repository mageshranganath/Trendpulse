        <item name="iconTint">@color/colorTextPrimary</item>
        <item name="strokeColor">@color/colorTextPrimary</item>
    </style>

    <style name="Widget.CurrencyTrend.Button.Tile" parent="Widget.MaterialComponents.Button.OutlinedButton">
